
$RegPath   = "HKLM:\SOFTWARE\Microsoft\Windows Advanced Threat Protection\Status"
$ValueName = "OrgId"

try {
   
    $orgId = (Get-ItemProperty -Path $RegPath -Name $ValueName -ErrorAction Stop).$ValueName

    
    if (-not [string]::IsNullOrEmpty($orgId) -and $orgId.Length -ge 7) {
        
        $firstSeven = $orgId.Substring(0, 7)

        
        if ($firstSeven -match '^[0-9]+$') {
            Write-Output "Compliant"
            exit 0
        }
        else {
            Write-Output "Non-Compliant: первые 7 символов не являются только цифрами"
            exit 1
        }
    }
    else {
        Write-Output "Non-Compliant: значение реестра отсутствует или короче 7 символов"
        exit 1
    }
}
catch {
    Write-Output "Non-Compliant: не удалось прочитать значение реестра (ключ или значение отсутствует)"
    exit 1
}


